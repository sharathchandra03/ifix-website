# Server Configuration
PORT=5000
# IMPORTANT: set to "production" on the live server. In production the app
# enforces strict CORS, hides internal error details, and refuses to start
# without a strong JWT_SECRET.
NODE_ENV=production

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ifix_db
DB_PORT=3306

# # Razorpay API Keys
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google API Configuration
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key
GOOGLE_SHEETS_CLIENT_EMAIL=your_service_account_email
GOOGLE_SHEETS_PRIVATE_KEY=your_private_key
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_PRIVATE_KEY_ID=your_google_private_key_id
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_SHEETS_RANGE=Contacts!A:H
YOUTUBE_API_KEY=your_youtube_api_key

# Image Storage (Cloudinary - recommended for hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ifix/blogs

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# JWT Secret — generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server REFUSES to start in production if this is missing or insecure.
JWT_SECRET=your_jwt_secret_key_here
# Optional: token lifetime (default 24h)
JWT_EXPIRES_IN=24h

# Frontend URL(s) for CORS — comma-separate multiple origins.
# Example: https://ifixindiaacademy.in,https://www.ifixindiaacademy.in
FRONTEND_URL=http://localhost:3000

# Set to "true" only when troubleshooting Google Sheets credentials.
# Leave unset/false in production — it prints credential diagnostics to logs.
GOOGLE_SHEETS_DEBUG=false
